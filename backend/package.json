{
  "name": "fireshield-backend",
  "version": "1.0.0",
  "description": "FireShield AI backend — Express + Socket.io + Google OAuth",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently -n \"SERVER,PYTHON,RETRAIN\" -c \"green,yellow,red\" \"nodemon server.js\" \"venv/bin/python3 fire_ws.py --model models/fire.pt\" \"venv/bin/python3 retrain.py\"",
    "dev:noretrain": "concurrently -n \"SERVER,PYTHON\" -c \"green,yellow\" \"nodemon server.js\" \"venv/bin/python3 fire_ws.py --model models/fire.pt\""
  },
  "dependencies": {
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.6.0",
    "passport-google-oauth20": "^2.0.0",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.2"
  }
}
